# =========================
# Shared
# =========================
POSTGRES_DB=sagai
POSTGRES_USER=sagai
POSTGRES_PASSWORD=change_this_password
POSTGRES_PORT=5432

# =========================
# Backend / AI API
# =========================
APP_NAME=SAGAI API
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
API_PORT=8000
DATABASE_URL=postgresql+psycopg://sagai:change_this_password@postgres:5432/sagai

CORS_ALLOWED_ORIGINS=http://localhost:3000
KNOWLEDGE_DIR=/app/knowledge
PROMPT_FILE=/app/knowledge/prompt/system_prompt.md

# Embeddings Sprint 1
# hash = legado/fallback determinístico; ollama = embeddings reais via Ollama /api/embed.
EMBEDDINGS_PROVIDER=ollama
EMBEDDINGS_MODEL=embeddinggemma
EMBEDDINGS_BASE_URL=http://host.docker.internal:11434
EMBEDDINGS_TIMEOUT_SECONDS=120
EMBEDDINGS_VECTOR_DIMENSIONS=768
EMBEDDINGS_BATCH_SIZE=16
EMBEDDINGS_FALLBACK_PROVIDER=hash
EMBEDDINGS_ENABLE_FALLBACK=true

# Coluna legada knowledge_chunks.embedding; não alterar sem migração planejada.
VECTOR_DIMENSIONS=256

# Retrieval Sprint 2
# vector = somente pgvector; lexical = somente busca textual; hybrid = combinação vetorial + textual com reranking leve.
RETRIEVAL_TOP_K=5
RETRIEVAL_STRATEGY=hybrid
RETRIEVAL_CANDIDATE_MULTIPLIER=4
RETRIEVAL_VECTOR_WEIGHT=0.65
RETRIEVAL_LEXICAL_WEIGHT=0.25
RETRIEVAL_METADATA_WEIGHT=0.10
RETRIEVAL_MIN_SCORE=0.12
RETRIEVAL_ENABLE_RERANKING=true
RETRIEVAL_LEXICAL_LANGUAGE=portuguese
MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# LLM
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:1b
LLM_BASE_URL=http://host.docker.internal:11434
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=300

# Ollama local legado / compatibilidade
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:1b

# Security
ADMIN_API_KEY=change_this_admin_key

# =========================
# Frontend
# =========================
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=SAGAI
FRONTEND_PORT=3000

# Confidence
CONFIDENCE_THRESHOLD_HIGH=0.85
CONFIDENCE_THRESHOLD_MEDIUM=0.70

# Learning / Training
# Candidatos com confidence_score igual ou maior que este valor podem ser aprovados em lote.
TRAINING_AUTO_APPROVE_MIN_CONFIDENCE=0.60
